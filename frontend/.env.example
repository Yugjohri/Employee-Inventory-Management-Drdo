# Copy this file to .env and fill in the values from your Supabase project:
#   Supabase Dashboard -> Project Settings -> Data API
#
# Only the "anon public" key belongs here. Never put the service_role key in
# a VITE_ variable -- anything prefixed VITE_ is compil
# bundle and visible to anyone who opens the site. The anon key is safe to
# expose because Row Level Security (backend/supabase/s
# actually decides which rows each signed-in user can read.
#
# .env is gitignored. Keep it that way.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
